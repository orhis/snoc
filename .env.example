# Szkielet FAM — skopiuj do .env (chmod 600) i uzupełnij. .env NIE trafia do repo.

# Admin (utwórz konto: python -m scripts.bootstrap_admin admin "haslo" "Administrator"
#   — tworzy usera w bazie; albo użyj fam_auth.hash_password do samego hasha do .env)
ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=

# Baza (ścieżka wewnątrz kontenera; data/ idzie przez bind mount)
DB_PATH=data/app.db

# 2FA wymagane dla adminów?
REQUIRE_2FA=false

# SMTP (gdy dojdzie moduł email)
SMTP_HOST=
SMTP_PORT=587
